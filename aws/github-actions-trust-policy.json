{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GitHubActionsAssumeRole",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::357151442673:oidc-provider/token.actions.githubusercontent.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
          "token.actions.githubusercontent.com:sub": "repo:it-infra-meetup/website:environment:production"
        }
      }
    }
  ]
}
