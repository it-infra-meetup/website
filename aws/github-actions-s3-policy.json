{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListWebsitePrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::it-infra-meetup",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "website",
            "website/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadWriteWebsiteObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::it-infra-meetup/website/*"
    },
    {
      "Sid": "InvalidateCloudFrontDistribution",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "arn:aws:cloudfront::357151442673:distribution/EW606QTVMD4I0"
    }
  ]
}
