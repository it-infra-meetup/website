{
  "name": "website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:vrt": "vitest run --config vitest.config.ts",
    "test:vrt:update": "vitest run --config vitest.config.ts --update"
  },
  "dependencies": {
    "@lucide/vue": "1.17.0",
    "@vrc-ta-hub/client": "workspace:*",
    "gsap": "3.15.0",
    "pinia": "3.0.4",
    "vue": "3.5.35",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@pinia/testing": "1.0.3",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/browser-playwright": "4.1.8",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "eslint-plugin-vue": "10.9.1",
    "playwright": "1.60.0",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vitest-browser-vue": "2.1.0",
    "vue-tsc": "3.3.3"
  }
}
